<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="MyAvaloniaApp.Views.EditTemplateWindow"
        Title="Список доступных поверяемых приборов" Width="1024" Height="768">

        <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

        <!-- Тип устройства (ComboBox) -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" Spacing="8">
            <TextBlock Text="Тип устройства:" VerticalAlignment="Center" Width="120"/>
            <ComboBox x:Name="cbDeviceType" Width="300" SelectedIndex="0">
                
            </ComboBox>
        </StackPanel>

        <!-- Основные сведения об эталоне (GroupBox) -->
        <GroupBox Grid.Row="1" Header="Основные сведения об эталоне" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Полное наименование эталона:" Margin="6,4,6,4"/>
                <TextBox x:Name="tbFullName" Grid.Row="0" Grid.Column="1" Margin="6,4,6,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Серийный номер:" Margin="6,4,6,4"/>
                <TextBox x:Name="tbSerialNumber" Grid.Row="1" Grid.Column="1" Margin="6,4,6,4"/>
            </Grid>
        </GroupBox>

        <!-- Погрешность измерений эталона (GroupBox) -->
        <GroupBox Grid.Row="2" Header="Погрешность измерений эталона" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Погрешность:" Margin="6,4,6,4"/>
                <TextBox x:Name="tbInaccuracy" Grid.Row="0" Grid.Column="1" Margin="6,4,6,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Способ нормировки погрешности измерений эталона:" Margin="6,4,6,4"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="16">
                    <RadioButton x:Name="RbPercentD" Content="%Д" IsChecked="True" Margin="0,4,0,4"/>
                    <RadioButton x:Name="RbPercentDIV" Content="%Д / %ИВ" Margin="0,4,0,4"/>
                    <RadioButton x:Name="RbDivConst" Content="%ИВ + Const" Margin="0,4,0,4"/>
                    <RadioButton x:Name="RbAbs" Content="Абс." Margin="0,4,0,4"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Настройка рабочего диапазона (GroupBox) -->
        <GroupBox Grid.Row="3" Header="Настройка рабочего диапазона" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Текущий диапазон:" Margin="6,4,6,4"/>
                <ComboBox x:Name="cbRange" Grid.Row="0" Grid.Column="1" Width="200" Margin="6,4,6,4">
                    
                </ComboBox>
            </Grid>
        </GroupBox>

        <!-- Параметры рабочего диапазона (GroupBox) -->
        <GroupBox Grid.Row="4" Header="Параметры рабочего диапазона" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Единицы измерения:" Margin="6,4,6,4"/>
                <ComboBox Grid.Row="0" Grid.Column="1" Width="200" Margin="6,4,6,4">
                    <ComboBoxItem x:Name="RbPa">Па</ComboBoxItem>
                    <ComboBoxItem x:Name="RbkPa">кПа</ComboBoxItem>
					<ComboBoxItem x:Name="RbMPa">МПа</ComboBoxItem>
                    <ComboBoxItem x:Name="RbmA">мА</ComboBoxItem>
                    <ComboBoxItem x:Name="RbV">В</ComboBoxItem>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="НПИ:" Margin="6,4,6,4"/>
                <TextBox x:Name="tbLowerLimit" Grid.Row="1" Grid.Column="1" Margin="6,4,6,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="ВПИ:" Margin="6,4,6,4"/>
                <TextBox x:Name="tbUpperLimit" Grid.Row="2" Grid.Column="1" Margin="6,4,6,4"/>
            </Grid>
        </GroupBox>

        <!-- Кнопки OK и Отмена (внизу, прижаты вправо) -->
        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                    HorizontalAlignment="Right" Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
            <Button Content="OK" Width="80" Click="BtnOkClicked"/>
            <Button Content="Отмена" Width="80"/>
        </StackPanel>
    </Grid>
</Window>