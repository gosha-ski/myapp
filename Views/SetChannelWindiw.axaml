<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MyAvaloniaApp.Views.SetChannelWindow"
        Title="Выбор канала"
        Width="300" Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, *" Margin="15">
        
        <GroupBox Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
            <GroupBox.Header>
                <TextBlock Text="Номер измерительного канала" FontWeight="Bold"/>
            </GroupBox.Header>
            
            <TextBox x:Name="ChannelInput" 
                     VerticalAlignment="Center"
                     HorizontalAlignment="Stretch"
                     Margin="5">
                <TextBox.Styles>
                    <Style Selector="TextBox:focus">
                        <Setter Property="BorderBrush" Value="Blue"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </Style>
                </TextBox.Styles>
            </TextBox>
        </GroupBox>

        <Button Grid.Row="2" Grid.Column="0" 
                Content="OK" 
                Margin="0,0,10,0"
                Click="OnOkClick"
                Classes="Accent"/>
        
        <Button Grid.Row="2" Grid.Column="1" 
                Content="Отмена" 
                Margin="10,0,0,0"
                Click="OnCancelClick"/>
    </Grid>
</Window>
