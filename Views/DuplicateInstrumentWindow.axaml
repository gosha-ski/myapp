<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MyAvaloniaApp.Views.DuplicateInstrumentWindow"
        Title="Добавить прибор"
        Width="350" Height="200">
    <StackPanel Margin="15">
        <TextBlock Text="Серийный номер" Margin="0,0,0,5"/>
        <TextBox Name="SerialNumberInput" Margin="0,0,0,15"/>

        <TextBlock Text="Инвентарный номер" Margin="0,0,0,5"/>
        <TextBox Name="InventoryNumberInput" Margin="0,0,0,15"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="ОК" Name="OkButton" Margin="0,0,10,0" Width="70"/>
            <Button Content="Отмена" Name="CancelButton" Width="70"/>
        </StackPanel>
    </StackPanel>
</Window>