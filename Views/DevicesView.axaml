<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:MyAvaloniaApp.Views"
             x:Class="MyAvaloniaApp.Views.DevicesView"
             x:DataType="local:DevicesView"
             >
    <Grid RowDefinitions="*, Auto">
        <!-- Таблица приборов -->
        <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="5">
            <DataGrid ItemsSource="{Binding Devices}" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№ канала" Binding="{Binding ChannelNumber}" Width="100"/>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="200"/>
                    <DataGridTextColumn Header="Серийный №" Binding="{Binding SerialNumber}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Панель действий (справа, как на скриншоте) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Добавить в список" Click="OnAddClick" Margin="0,0,5,0" Width="120"/>
            <Button Content="Удалить из списка" Click="OnRemoveClick" Margin="0,0,5,0" Width="120"/>
            <Button Content="Установить № канала" Click="OnSetChannelClick" Width="150"/>
        </StackPanel>
    </Grid>
</UserControl>